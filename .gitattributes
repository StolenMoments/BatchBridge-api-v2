# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Explicitly declare text files as LF
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
gradlew text eol=lf

# Windows batch files stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.class binary
*.zip binary
*.tar binary
*.gz binary
